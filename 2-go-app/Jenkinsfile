// Jenkinsfile Groovy
pipeline {
    agent {
        node {
            label 'built-in'
        }
    }

    tools {
        go 'go-1.26.3' 
    }
    
//     triggers {
//        githubPush() 
//    }
    
    environment {
        APP_NAME = "go-app"
        DOCKER_USER = "andreasprinz"
        DOCKER_PASS = "dockerhub-deploy-token"
	DOCKER_IMAGE = "${DOCKER_USER}" + "/" + "${APP_NAME}"
        // Приклад адреси Nexus у кластері:
//        DOCKER_IMAGE = "nexus-nexus-repository-manager.nexus.svc.cluster.local:8082/go-app"
        VERSION = "v2.0.0-b${BUILD_NUMBER}"
        
        REPO_URL = "github.com/andreas-prinz/devops-diploma-project"
        REPO_BRANCH = "master"
        REPO_TOKEN = "github-deploy-token"
        
        SONAR_SERVER = 'sonarqube-server'
        SONAR_SCANNER_HOME = tool 'sonarqube-scanner'
        SONAR_TOKEN = 'jenkins-sonarqube-token'
    }

    stages {
        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout from SCM') {
            steps {
                git branch: "${REPO_BRANCH}", credentialsId: "${REPO_TOKEN}", url: "https://" + "${REPO_URL}"
            }
        }

        stage('Test') {
            steps {
//                withEnv(['CGO_ENABLED=1']) {
                dir('2-go-app') {
                    sh 'pwd'
                    sh 'ls -la'
                    sh '''
                        if [ ! -f go.mod ]; then
                            go mod init my-diploma-app
                            go mod tidy
                        fi
                    '''
                    // -v дає детальний лог кожного тесту
                    // -race перевіряє код на проблеми з конкурентністю (race conditions)
                    sh 'go test -v -coverprofile=coverage.out ./...'
//                }
                }
            }
        }
        
        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv("${SONAR_SERVER}") {
                    withCredentials([string(credentialsId: "${SONAR_TOKEN}", variable: 'SONAR_TOKEN')]) {
                        sh "SONAR_TOKEN=${SONAR_TOKEN} ${SONAR_SCANNER_HOME}/bin/sonar-scanner"
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 10, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true, credentialsId: "${SONAR_TOKEN}"
                }
            }
        }
        
        stage('Build & Push Docker Image') {
            agent {
                kubernetes {
                    yaml '''
apiVersion: v1
kind: Pod
spec:
  containers:
  - name: docker-cli
    image: docker:27.0-cli
    command: ["cat"]
    tty: true
    env:
    - name: DOCKER_HOST
      value: tcp://localhost:2375
  - name: dind
    image: docker:27.0-dind
    securityContext:
      privileged: true
    env:
    - name: DOCKER_TLS_CERTDIR
      value: ""
'''
                }
            }
            
            steps {
                withEnv(["DOCKER_IMAGE=${DOCKER_IMAGE}", "VERSION=${VERSION}"]) {
                    withCredentials([usernamePassword(credentialsId: "${DOCKER_PASS}", usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                        container('docker-cli') {
                            sh '''
                                sleep 5
                                cd 2-go-app/
                                if [ ! -f go.mod ]; then
                                    go mod init my-diploma-app
                                    go mod tidy
                                fi
                                ls -la                        
                                echo "${DOCKER_PASS}" | docker login -u "${DOCKER_USER}" --password-stdin
                        
                                docker build -t ${DOCKER_IMAGE}:${VERSION} -t ${DOCKER_IMAGE}:latest .
                        
                                docker push ${DOCKER_IMAGE}:${VERSION}
                            '''
                        }
                    }
                }
            }
        }
            
        stage('Update Manifests (GitOps)') {
            steps {
                // Jenkins заходить у репозиторій з маніфестами і змінює тег образу
                // Це тригерить ArgoCD на розгортання
                withCredentials([usernamePassword(credentialsId: "${REPO_TOKEN}", usernameVariable: 'GIT_USER', passwordVariable: 'GIT_TOKEN')]) {
                    withEnv(["DOCKER_IMAGE=${DOCKER_IMAGE}", "VERSION=${VERSION}", "REPO_URL=${REPO_URL}", "REPO_BRANCH=${REPO_BRANCH}"]) {
                        sh '''
                           git config --global user.email "jenkins@ci-cd.local"
                           git config --global user.name "Jenkins CI"
                           
                           pwd
                           ls -la
                           
                           sed -i "s|image: .*|image: ${DOCKER_IMAGE}:${VERSION}|" 3-k8s-manifests/rollout.yaml
                           git diff 3-k8s-manifests/rollout.yaml
                           git add 3-k8s-manifests/rollout.yaml
                           git commit -m "Update image to ${VERSION} [skip ci]"
                           git push https://${GIT_USER}:${GIT_TOKEN}@${REPO_URL} ${REPO_BRANCH}
                        '''
                    }
                }
            }
        }
    }
}
