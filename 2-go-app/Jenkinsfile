// Jenkinsfile Groovy
pipeline {
    // Пайплайн запускається на вбудованому (майстер) агенті Jenkins
    agent {
        node {
            label 'built-in'
        }
    }

    // Підключення інструментів розробки, налаштованих у Jenkins Global Tool Configuration
    tools {
        go 'go-1.26.3' 
    }
    
//     triggers {
//        githubPush() 
//    }
    
    // Секція змінних оточення (глобальні налаштування проекту)
    environment {
        APP_NAME = "go-app"
        DOCKER_USER = "andreasprinz"
        DOCKER_PASS = "dockerhub-deploy-token" // ID облікових даних Jenkins для Docker Hub
	DOCKER_IMAGE = "${DOCKER_USER}" + "/" + "${APP_NAME}"

	// Генеруємо унікальну версію для кожного білду (наприклад, v2.0.0-b42)
	VERSION = "v1.0.0-b${BUILD_NUMBER}"
        
        // Налаштування Git-репозиторію для автоматичного пушу маніфестів
        REPO_URL = "github.com/andreas-prinz/devops-diploma-project"
        REPO_BRANCH = "master"
        REPO_TOKEN = "github-deploy-token" // ID токена доступу Jenkins до GitHub (PAT)
        
        // Налаштування для аналізу якості коду в SonarQube
        SONAR_SERVER = 'sonarqube-server'
        SONAR_SCANNER_HOME = tool 'sonarqube-scanner'
        SONAR_TOKEN = 'jenkins-sonarqube-token'
    }

    stages {
        // ЕТАП 1: Захист від нескінченного циклу (Guard)
        stage('Guard: Check Skip CI') {
            steps {
               script {
                    // Отримуємо хеш поточного комміту, який спричинив цей запуск
                    def currentCommit = sh(script: 'git rev-parse HEAD', returnStdout: true).trim()
                    echo "Поточний хеш комміту: ${currentCommit}"
                    
                    // Отримуємо текст останнього комміту
                    def commitMessage = sh(script: 'git log -1 --pretty=%B', returnStdout: true).trim()
                    echo "Текст останнього комміту: ${commitMessage}"
                    
                    // Використовуємо легальну змінну Jenkins для отримання хешу минулого успішного білду
                    def previousCommit = env.GIT_PREVIOUS_SUCCESSFUL_COMMIT
                    echo "Хеш комміту попередньої успішної збірки: ${previousCommit}"
                    
                    // ПЕРЕВІРКА 1: Якщо хеш збігається з минулим успішним (хибний запуск Jenkins при No Changes)
                    if (previousCommit && currentCommit == previousCommit) {
                        echo "Jenkins викликав збірку помилково (нових коммітів у Git немає). Зупиняємо пайплайн."
                        currentBuild.result = 'SUCCESS'
                    }
                    
                    // ПЕРЕВІРКА 2: Якщо комміт новий, але містить стоп-флаг [skip ci] від кроку автоматизації
                    if (commitMessage.toLowerCase().contains("skip ci")) {
                        echo "Виявлено прапор [skip ci]. Наступні етапи будуть пропущені для збереження ресурсів."
                        currentBuild.result = 'SUCCESS'
                    }
                }
            }
        }
        
        // ЕТАП 2: Очищення робочого простору перед початком роботи
        stage('Clean Workspace') {
            when { expression { currentBuild.result != 'SUCCESS' } }
            steps {
                cleanWs()
            }
        }

        // ЕТАП 3: Завантаження свіжого коду з Git-репозиторію
        stage('Checkout from SCM') {
            when { expression { currentBuild.result != 'SUCCESS' } }
            steps {
                git branch: "${REPO_BRANCH}", credentialsId: "${REPO_TOKEN}", url: "https://" + "${REPO_URL}"
            }
        }

        // ЕТАП 4: Тестування додатку на Go
        stage('Test') {
            when { expression { currentBuild.result != 'SUCCESS' } }
            steps {
                dir('2-go-app') {
                    sh 'pwd'
                    sh 'ls -la'
                    sh '''
                        # Перевіряємо наявність go.mod, якщо немає — ініціалізуємо для збірки тесту
                        if [ ! -f go.mod ]; then
                            go mod init my-diploma-app
                            go mod tidy
                        fi
                    '''
                    // Запуск тестів із детальним логом (-v) та збором метрик покриття коду
                    sh 'go test -v -coverprofile=coverage.out ./...'
                }
            }
        }
        
        stage('OWASP Dependency-Check') {
            when { expression { currentBuild.result != 'SUCCESS' } }
            steps {
                script {
                    // Отримуємо точний системний шлях до Go, який Jenkins встановив через tools
                    def goHome = tool name: 'go-1.26.3', type: 'go'
                    // Примусово додаємо шлях до Go в PATH для цього кроку
                    withEnv(["PATH+GO=${goHome}/bin"]) {
                        dir('2-go-app') {
                            sh 'pwd'
                            sh 'ls -la'
                            sh '''
                                echo \\{\\} > package.json
                                echo \\"dependencies\\": \\{\\"jquery\\": \\"1.12.0\\"\\} > package.json
                            '''    
                            withCredentials([string(credentialsId: 'owasp-nvd-api-key-id', variable: 'NVD_KEY')]) {
                                // Сканування go.mod / go.sum, назва інсталяції: 'OWASP-Default'
                                dependencyCheck additionalArguments: '--scan . --format HTML --format XML --out ../OWASP-Reports --nvdApiKey $NVD_KEY --noupdate  --enableExperimental', 
                                        odcInstallation: 'OWASP-Default'
                                
                            }
                        }
                        // Тепер Jenkins шукає звіт у корені робочої директорії, де він і лежить
                        dependencyCheckPublisher pattern: 'OWASP-Reports/dependency-check-report.xml'
                    }
                }
            }
        }
        
        // ЕТАП 5: Статичний аналіз коду в SonarQube
        stage('SonarQube Analysis') {
            when { expression { currentBuild.result != 'SUCCESS' } }
            steps {
                withSonarQubeEnv("${SONAR_SERVER}") {
                    withCredentials([string(credentialsId: "${SONAR_TOKEN}", variable: 'SONAR_TOKEN')]) {
                        // Надсилаємо результати тестування та покриття (coverage.out) до SonarQube
                        sh '${SONAR_SCANNER_HOME}/bin/sonar-scanner -Dsonar.token=${SONAR_TOKEN} -Dsonar.projectKey=my-go-web-app -Dsonar.projectName="My Go Web Application" -Dsonar.sources=2-go-app -Dsonar.exclusions="**/*_test.go,**/vendor/**" -Dsonar.tests=2-go-app -Dsonar.test.inclusions="**/*_test.go" -Dsonar.go.coverage.reportPaths=2-go-app/coverage.out -Dsonar.exclusions=**/OWASP-Reports/**'
                    }
                }
            }
        }

        // ЕТАП 6: Перевірка воріт якості (Quality Gate)
        stage('Quality Gate') {
            when { expression { currentBuild.result != 'SUCCESS' } }
            steps {
                // Очікуємо відповіді від сервера SonarQube. Якщо код низької якості, пайплайн впаде
                timeout(time: 10, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true, credentialsId: "${SONAR_TOKEN}"
                }
            }
        }
        
        // ЕТАП 7: Збірка Docker-образу з оптимізованим кэшуванням (Buildx + DinD)
        stage('Build & Push Docker Image') {
            agent {
                kubernetes {
                    // Створюємо динамічний окремий под для ізольованої збірки Docker
                    yaml '''
apiVersion: v1
kind: Pod
spec:
  containers:
  - name: docker-cli
    image: docker:27.0-cli
    command: ["cat"]
    tty: true
    env:
    - name: DOCKER_HOST
      value: tcp://localhost:2375
  - name: dind
    image: docker:27.0-dind
    securityContext:
      privileged: true
    env:
    - name: DOCKER_TLS_CERTDIR
      value: ""
'''
                }
            }
            when { expression { currentBuild.result != 'SUCCESS' } }
            steps {
                withEnv(["DOCKER_IMAGE=${DOCKER_IMAGE}", "VERSION=${VERSION}"]) {
                    withCredentials([usernamePassword(credentialsId: "${DOCKER_PASS}", usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                        container('docker-cli') {
                            sh '''
                                set -x
                                # Очікуємо 5 секунд, поки підніметься мережевий сокет у сусідньому контейнері DinD
                                sleep 5
                                cd 2-go-app/
                                if [ ! -f go.mod ]; then
                                    go mod init my-diploma-app
                                    go mod tidy
                                fi
                                go get golang.org/x/crypto@v0.0.0-20210921155107-089bfa567519
                                ls -la
                                
                                # Швидке встановлення утиліти Trivy CLI
                                apk add --no-cache curl wget
                                wget https://github.com/aquasecurity/trivy/releases/download/v0.70.0/trivy_0.70.0_Linux-64bit.tar.gz
                                tar -zxvf trivy_0.70.0_Linux-64bit.tar.gz trivy
                                chmod +x ./trivy
                                mv trivy /usr/local/bin/
                                rm trivy_0.70.0_Linux-64bit.tar.gz || true
                    
                                # Авторизуємося в Docker Hub (у тихому режимі для безпеки логів)
                                echo "${DOCKER_PASS}" | docker login -u "${DOCKER_USER}" --password-stdin
                                
                                # Активуємо сучасний розширений двигун збірки Buildx
                                docker buildx create --use --name mybuilder
                                
                                # Збірка з оптимізацією: завантажуємо та зберігаємо кэш шарів прямо в Docker Hub (тег :cache)
                                # Це прискорює повторні збірки в рази, оскільки базові шари Go не скачуються заново
                                docker buildx build \
                                    --cache-from=type=registry,ref=${DOCKER_IMAGE}:cache \
                                    --cache-to=type=registry,ref=${DOCKER_IMAGE}:cache,mode=max \
                                    -t ${DOCKER_IMAGE}:${VERSION} \
                                    --push .
                                
                                # Сканування образу через Trivy (HIGH,CRITICAL)
                                echo "--> Аналіз безпеки віддаленого Docker-образу через Trivy..."
                                trivy image --severity HIGH,CRITICAL --exit-code 0 ${DOCKER_IMAGE}:${VERSION}
                                
                                # Видаляємо конфіг з токеном авторизації після завершення пушу
                                rm -f /root/.docker/config.json
                            '''
                        }
                    }
                }
            }
        }
            
        // ЕТАП 8: Оновлення Kubernetes маніфестів для Argo CD (GitOps)
        stage('Update Manifests (GitOps)') {
            when { expression { currentBuild.result != 'SUCCESS' } }
            steps {
                // Jenkins оновлює файл конфігурації k8s, вписуючи туди нову унікальну версію образу
                // Argo CD автоматично помітить цю зміну у Git та оновить додаток у кластері
                withCredentials([usernamePassword(credentialsId: "${REPO_TOKEN}", usernameVariable: 'GIT_USER', passwordVariable: 'GIT_TOKEN')]) {
                    withEnv(["DOCKER_IMAGE=${DOCKER_IMAGE}", "VERSION=${VERSION}", "REPO_URL=${REPO_URL}", "REPO_BRANCH=${REPO_BRANCH}"]) {
                        sh '''
                           git config --global user.email "jenkins@ci-cd.local"
                           git config --global user.name "Jenkins CI"
                           
                           pwd
                           ls -la
                           
                           # Утилітою sed динамічно замінюємо старий тег образу на новий у файлі конфігурації
                           sed -i "s|image: .*|image: ${DOCKER_IMAGE}:${VERSION}|" 3-k8s-manifests/rollout.yaml
                           
                           # Виводимо у лог зміни для перевірки коректності перед коммітом
                           git diff 3-k8s-manifests/rollout.yaml
                           
                           # Фіксуємо зміни та робимо пуш назад у GitHub обов'язково з прапором [skip ci]
                           git add 3-k8s-manifests/rollout.yaml
                           git commit -m "Update image to ${VERSION} [skip ci]"
                           git push https://${GIT_USER}:${GIT_TOKEN}@${REPO_URL} ${REPO_BRANCH}                           
                        '''
                    }
                }
            }
        }
    }
}
